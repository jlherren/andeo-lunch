{
    "compilerOptions": {
        "target": "ES2024",
        "module": "NodeNext",
        "strict": true,
        "noEmit": true,

        "allowImportingTsExtensions": true,
        "erasableSyntaxOnly": true,
        "noImplicitAny": true,
        "noImplicitReturns": true,
        "noUnusedLocals": true
    },
    "include": [
        "migrations/**/*.ts",
        "src/**/*.ts"
    ]
}
